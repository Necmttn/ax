node_modules/
data/
*.log
.env
.env.local
bun.lockb
.references/
*.tsbuildinfo
dist/
.turbo/
.worktrees/
.superpowers/

# local agent + harness state
.ax/
.claude/agents/
# committed named workflows (Bun-repo pattern) - keep *.workflow.js versioned,
# ignore everything else in the dir (gitignore can't re-include inside an
# excluded DIRECTORY, so exclude contents with /* instead)
.claude/workflows/*
!.claude/workflows/*.workflow.js
.claude/worktrees/
.claude/scheduled_tasks.lock

# python build cruft
__pycache__/
*.pyc

# soloterm dev-runner config (personal)
solo.yml

# macOS cruft
.DS_Store

# studio build output (daemon dist/ is covered by the generic dist/ rule)
apps/studio/dist-studio/
apps/studio/dist-desktop/
# studio staged into the site by scripts/stage-studio.ts (generated, not committed)
apps/site/public/studio/

# local dogfood outputs (HTML reports, profiling scratch)
dogfood-output/
checkpoints/

# generated preview HTML from prototype scripts - contains real transcript text
scripts/prototypes/*-preview.html

# nix
result
result-*
.direnv/

# SurrealDB CLI scratch
history.txt
.surmlcache/

# landing port scratchpad
apps/site/PORT-NOTES-LANDING.md
# origin port scratchpad
apps/site/PORT-NOTES-ORIGIN.md

# site workspace
apps/site/dist
apps/site/.tanstack
apps/site/.wrangler
apps/site/node_modules
apps/site/app/routeTree.gen.ts
apps/site/.content-collections

# generated MDX partial - rebuilt by scripts/extract-stage-rationale.ts on every dev/build
docs/how-ax-sees-your-work.generated.mdx

# scratch screenshots from landing iteration
apps/site/.tmp-shots/

# studio-desktop electron build + packaged + vendored/staged resources
apps/studio-desktop/dist-electron/
apps/studio-desktop/dist-release/
apps/studio-desktop/resources/bin/
apps/studio-desktop/resources/ax-src/
apps/studio-desktop/resources/studio/

# launch/marketing assets - heavy media (30MB+), captured locally, unredacted
docs/launch-proof/

# ETag cache for nightly community compile - machine-local, no cross-run persistence needed
community/.gist-etag-cache.json
