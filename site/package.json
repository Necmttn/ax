{
  "name": "ax-site",
  "version": "0.0.0",
  "license": "AGPL-3.0-only",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "bun ../scripts/extract-stage-rationale.ts && cp ../install.sh public/install",
    "prebuild": "bun ../scripts/extract-stage-rationale.ts && cp ../install.sh public/install",
    "dev": "vite dev",
    "build": "bun ../scripts/extract-stage-rationale.ts && cp ../install.sh public/install && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "deploy": "bun run build && wrangler deploy --config dist/server/wrangler.json",
    "deploy:check": "bun run build && wrangler deploy --config dist/server/wrangler.json --dry-run"
  },
  "dependencies": {
    "@content-collections/core": "^0.15.1",
    "@content-collections/mdx": "^0.2.2",
    "@content-collections/vite": "^0.3.0",
    "@tanstack/react-router": "^1.166.0",
    "@tanstack/react-start": "^1.166.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.1.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.29.0",
    "@tailwindcss/vite": "^4.2.0",
    "@tanstack/router-devtools": "^1.166.0",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.3",
    "wrangler": "^3.78.0"
  }
}
