{
  "name": "axctl",
  "version": "0.1.1",
  "description": "ax is local memory and telemetry for coding agents. axctl ingests transcripts, skills, and git history into SurrealDB; surfaces what skills are worth keeping and what the user actually does on demand.",
  "type": "module",
  "bin": {
    "axctl": "./bin/axctl"
  },
  "scripts": {
    "prepare": "effect-language-service patch",
    "typecheck": "tsc --noEmit",
    "ingest": "bun src/cli/index.ts ingest",
    "search": "bun src/cli/index.ts search",
    "db:start": "scripts/db-start.sh",
    "db:stop": "scripts/db-stop.sh",
    "db:schema": "scripts/apply-schema.sh",
    "refs:setup": "scripts/setup-references.sh",
    "watcher:install": "bash scripts/install-watcher.sh",
    "watcher:uninstall": "bash scripts/uninstall-watcher.sh",
    "daemon:install": "bash scripts/install-daemon.sh",
    "daemon:uninstall": "bash scripts/uninstall-daemon.sh",
    "build": "bun build --compile --outfile=dist/axctl src/cli/index.ts",
    "check:cli-reference": "bun scripts/check-cli-reference.ts",
    "check:table-coverage": "bun scripts/check-table-coverage.ts",
    "dashboard:dev": "vite --config src/dashboard/web/vite.config.ts",
    "dashboard:build": "vite build --config src/dashboard/web/vite.config.ts",
    "serve": "bun src/cli/index.ts serve",
    "prototype:memory-context": "bun scripts/prototypes/ax-memory-context.ts",
    "prototype:file-context": "bun scripts/prototypes/ax-file-context.ts",
    "prototype:turn-references": "bun scripts/prototypes/ax-ingest-turn-references.ts"
  },
  "dependencies": {
    "@opentui/core": "^0.2.5",
    "@opentui/react": "^0.2.5",
    "@tanstack/react-query": "^5",
    "@wterm/core": "0.3.0",
    "@wterm/dom": "0.3.0",
    "effect": "^4.0.0-beta.64",
    "node-pty": "1.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "surrealdb": "^2.0.0",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@effect/language-service": "^0.85.1",
    "@tanstack/react-router": "^1.169",
    "@tanstack/router-plugin": "^1.167",
    "@types/bun": "latest",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6",
    "typescript": "^5.5.0",
    "vite": "^8"
  }
}
