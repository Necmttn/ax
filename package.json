{
  "name": "agentctl",
  "version": "0.1.0",
  "description": "Agent telemetry & taste graph for Claude Code. Ingests transcripts, skills, and git history into SurrealDB; surfaces 'what skills are worth keeping' and 'what does this user actually do' on demand.",
  "type": "module",
  "bin": {
    "agentctl": "./bin/agentctl"
  },
  "scripts": {
    "prepare": "effect-language-service patch",
    "typecheck": "tsc --noEmit",
    "ingest": "bun src/cli/index.ts ingest",
    "search": "bun src/cli/index.ts search",
    "db:start": "scripts/db-start.sh",
    "db:stop": "scripts/db-stop.sh",
    "db:schema": "scripts/apply-schema.sh",
    "refs:setup": "scripts/setup-references.sh",
    "watcher:install": "bash scripts/install-watcher.sh",
    "watcher:uninstall": "bash scripts/uninstall-watcher.sh",
    "daemon:install": "bash scripts/install-daemon.sh",
    "daemon:uninstall": "bash scripts/uninstall-daemon.sh",
    "build": "bun build --compile --outfile=dist/agentctl src/cli/index.ts"
  },
  "dependencies": {
    "@opentui/core": "^0.2.5",
    "@opentui/react": "^0.2.5",
    "effect": "^4.0.0-beta.64",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "surrealdb": "^2.0.0",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@effect/language-service": "^0.85.1",
    "@types/bun": "latest",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "typescript": "^5.5.0"
  }
}
