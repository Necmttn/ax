{
  "name": "axctl",
  "version": "0.38.1",
  "license": "AGPL-3.0-only",
  "description": "ax CLI - local memory and telemetry for coding agents. axctl ingests transcripts, skills, and git history into SurrealDB; surfaces what skills are worth keeping and what the user actually does on demand.",
  "type": "module",
  "bin": {
    "axctl": "./bin/axctl"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "bun ../../scripts/build-axctl.ts src/cli/index.ts dist/axctl",
    "dev": "bun src/cli/index.ts",
    "serve": "bun src/cli/index.ts serve",
    "ingest": "bun src/cli/index.ts ingest",
    "search": "bun src/cli/index.ts search",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "dashboard:dev": "bun --filter @ax/studio dev",
    "dashboard:build": "bun --filter @ax/studio build"
  },
  "dependencies": {
    "@ax-classifier/direction-event": "workspace:*",
    "@ax-classifier/verification-event": "workspace:*",
    "@ax/hooks-sdk": "workspace:*",
    "@ax/lib": "workspace:*",
    "@ax/schema": "workspace:*",
    "@durable-streams/client": "^0.2.6",
    "@durable-streams/server": "^0.3.5",
    "@effect/platform-bun": "catalog:",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentui/core": "^0.2.5",
    "@opentui/react": "^0.2.5",
    "@tanstack/react-query": "^5",
    "@wterm/core": "0.3.0",
    "@wterm/dom": "0.3.0",
    "effect": "catalog:",
    "node-pty": "1.1.0",
    "react": "^19.2.0",
    "smol-toml": "1.6.1",
    "surrealdb": "^2.0.0",
    "yaml": "^2.8.4",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@effect/language-service": "catalog:",
    "@tanstack/react-router": "^1.169",
    "@types/bun": "catalog:",
    "@types/react": "^19.2.0",
    "bun-types": "1.3.13",
    "typescript": "catalog:"
  }
}
